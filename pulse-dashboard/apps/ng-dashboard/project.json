{
  "name": "ng-dashboard",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/ng-dashboard/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputPath": "dist/apps/ng-dashboard",
      "options": {
        "outputPath": "dist/apps/ng-dashboard",
        "index": "apps/ng-dashboard/src/index.html",
        "browser": "apps/ng-dashboard/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/ng-dashboard/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/ng-dashboard/public"
          }
        ],
        "styles": [
          "apps/ng-dashboard/src/styles.scss"
        ],
        "scripts": []
      },
      "configurations": {
        "production": {
          "budgets": [
            { "type": "initial", "maximumWarning": "1mb", "maximumError": "2mb" },
            { "type": "anyComponentStyle", "maximumWarning": "32kb", "maximumError": "64kb" }
          ],
          "outputHashing": "all",
          "fileReplacements": [
            {
              "replace": "apps/ng-dashboard/src/environments/environment.ts",
              "with": "apps/ng-dashboard/src/environments/environment.prod.ts"
            }
          ]
        },
        "uat": {
          "fileReplacements": [
            {
              "replace": "apps/ng-dashboard/src/environments/environment.ts",
              "with": "apps/ng-dashboard/src/environments/environment.uat.ts"
            }
          ]
        },
        "test": {
          "fileReplacements": [
            {
              "replace": "apps/ng-dashboard/src/environments/environment.ts",
              "with": "apps/ng-dashboard/src/environments/environment.test.ts"
            }
          ]
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": { "buildTarget": "ng-dashboard:build:production" },
        "development": { "buildTarget": "ng-dashboard:build:development" }
      },
      "defaultConfiguration": "development",
      "options": {
        "port": 4200,
        "proxyConfig": "apps/ng-dashboard/proxy.conf.json"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/ng-dashboard/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    }
  }
}
